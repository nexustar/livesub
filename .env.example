# At least ONE ASR backend must be configured for the server to accept
# sessions: a cloud key (GEMINI_API_KEY, OPENAI_API_KEY, DASHSCOPE_API_KEY)
# OR a local binary (QWEN_ASR_BIN, VOXTRAL_BIN). Backends without their
# key / binary are hidden in the UI dropdown.

# Optional: Gemini as ASR (Gemini Live) and/or translation backend.
# GEMINI_API_KEY=your_key_here
# Optional model overrides
# GEMINI_ASR_MODEL=gemini-2.5-flash-native-audio-latest
# GEMINI_TRANSLATE_MODEL=gemini-2.5-flash-lite

# Optional: Claude as translation backend. Required when picking any of
# "Claude Haiku / Sonnet / Opus" in the UI, or for /api/hints (scene-seed
# → glossary research) which always uses Claude Haiku.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: DeepSeek as translation backend. Uses the anthropic-compatible
# endpoint, so the same SDK as Claude with a different base_url + api_key.
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_TRANSLATE_MODEL=deepseek-v4-flash

# Optional: OpenAI Realtime ASR (gpt-realtime-whisper, server VAD, true
# token-level streaming, ~$0.017/min). Required when picking
# "OpenAI Realtime" as the ASR backend in the UI, or for any openai-SDK
# translate backend defined in livesub.toml that uses OPENAI_API_KEY.
# OPENAI_API_KEY=sk-...
# OPENAI_REALTIME_MODEL=gpt-realtime-whisper

# Optional: DashScope cloud Qwen3-ASR-Flash-Realtime (Alibaba's hosted
# Qwen ASR, 16kHz native, server VAD, CJK-tuned, ~$0.005/min intl /
# $0.003/min China). Required only when picking "Qwen (cloud / DashScope)"
# as the ASR backend in the UI.
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
#   ↑ default; override to wss://dashscope.aliyuncs.com/api-ws/v1/realtime
#   for the mainland-China region.
# DASHSCOPE_REALTIME_MODEL=qwen3-asr-flash-realtime
# Server VAD threshold (Alibaba's official recommendation = 0.2):
#   0.0-1.0; lower = catch quieter speech but more noise-triggered
#   hallucinations. Bump up in noisy environments (cafe, BGM, fan).
# DASHSCOPE_VAD_THRESHOLD=0.2

# Optional: custom translate backends (local LLMs, routing services, etc.)
# live in livesub.toml — see livesub.toml.example.

# Optional: Qwen-ASR local backend. Build https://github.com/antirez/qwen-asr
# and point at the binary + downloaded model dir.
# QWEN_ASR_BIN=/abs/path/to/qwen_asr
# QWEN_ASR_MODEL_DIR=/abs/path/to/qwen3-asr-0.6b

# Optional: Voxtral local ASR (larger / more accurate than Qwen-0.6B,
# multilingual auto-detect). Build https://github.com/antirez/voxtral.c
# VOXTRAL_BIN=/abs/path/to/voxtral
# VOXTRAL_MODEL_DIR=/abs/path/to/voxtral-realtime-4b
# VOXTRAL_INTERVAL_SEC=2.0
